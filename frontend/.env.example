# Backend root URL only — no trailing slash, no /api suffix.
# Leave empty for local dev (uses Create React App proxy → http://localhost:5000).
# Production example: https://your-api.onrender.com
REACT_APP_API_URL=

# Use HashRouter (#/routes) so GitHub Pages works without SPA server redirects.
# Set to true for github.io deployments; omit or false for normal hosts (Netlify, etc.).
REACT_APP_USE_HASH_ROUTER=
