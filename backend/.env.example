PORT=5000
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
GEMINI_API_KEY=your_gemini_api_key_here
OPENROUTER_API_KEY=
OPENROUTER_MODEL=
NODE_ENV=development

# Production only: comma-separated browser origins allowed to call this API (your GitHub Pages or Netlify URL).
# Example: https://yourname.github.io,https://yourname.github.io/your-repo
FRONTEND_ORIGIN=

# Optional: serve CRA build from ../frontend/build on the same origin (set NODE_ENV=production).
SERVE_FRONTEND=

# Token control: each /chat/send request only loads the last N messages from the DB for the model (full thread stays in SQLite for the UI).
CHAT_HISTORY_MESSAGE_LIMIT=10
# Optional: max characters per past message in that API payload only (0 = no truncation).
CHAT_HISTORY_MAX_MESSAGE_CHARS=0

# Notes: OCR for scanned PDFs (Tesseract). Max pages to rasterize per upload (default 15).
OCR_MAX_PDF_PAGES=15
# Tesseract language pack(s), e.g. eng, fra, deu — combined with + : eng+fra
TESSERACT_LANG=eng
